# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: App Configuration
VITE_APP_NAME=ConsultantAI
VITE_MAX_FILE_SIZE_MB=10
VITE_MAX_CONCURRENT_UPLOADS=3

# NOTE: Anthropic API key is configured as a Supabase Edge Function secret.
# Set it via: supabase secrets set ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# The key is NEVER exposed to the browser.
